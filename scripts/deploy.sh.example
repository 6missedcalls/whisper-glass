#!/bin/bash
# Build, sign, and deploy WhisperGlass
#
# Setup:
#   1. Copy this file to scripts/deploy.sh
#   2. Set SIGNING_IDENTITY to your Apple Developer cert
#   3. chmod +x scripts/deploy.sh
#
# To find your signing identity:
#   security find-identity -v -p codesigning
set -e

cd "$(dirname "$0")/.."

# Replace with your own signing identity, or use "-" for ad-hoc
SIGNING_IDENTITY="${SIGNING_IDENTITY:--}"

echo "Building..."
swift build --configuration release

echo "Deploying to /Applications..."
pkill -f "WhisperGlass" 2>/dev/null || true
sleep 1

mkdir -p /Applications/WhisperGlass.app/Contents/MacOS
cp .build/release/WhisperGlass /Applications/WhisperGlass.app/Contents/MacOS/WhisperGlass
cp SupportingFiles/Info.plist /Applications/WhisperGlass.app/Contents/Info.plist

echo "Signing..."
codesign --force --deep --sign "$SIGNING_IDENTITY" /Applications/WhisperGlass.app

echo "Launching..."
open /Applications/WhisperGlass.app

echo "Done."
